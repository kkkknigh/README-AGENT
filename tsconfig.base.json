{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@readmeclaw/remote-contracts": ["./packages/remote-contracts/src/index.ts"],
      "@readmeclaw/shared-ui": ["./packages/shared-ui/src/index.ts"]
    }
  }
}
